{
  "name": "x402-facilitator-evm",
  "version": "0.1.0",
  "description": "Verify-only x402 facilitator for EVM chains — settles-by-verification on Robinhood Chain (eip155:4663) in USDG via EIP-3009",
  "type": "module",
  "main": "dist/index.js",
  "license": "MIT",
  "scripts": {
    "build": "wrangler deploy --dry-run --outdir dist",
    "type-check": "tsc --noEmit",
    "test": "node --experimental-strip-types --test test/*.test.ts",
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "sync:registry": "cp ../universal-blockchain-mcp/src/chains.ts src/chains.ts && node scripts/restore-vendor-header.mjs",
    "check:registry": "bash scripts/check-registry-sync.sh",
    "quality": "npm run check:registry && npm run type-check && npm run test"
  },
  "dependencies": {
    "hono": "^4.6.0",
    "viem": "^2.21.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20241127.0",
    "@types/node": "^26.1.1",
    "typescript": "^5.9.3",
    "wrangler": "^3.90.0"
  }
}
